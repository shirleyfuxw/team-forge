#!/usr/bin/env bash
# team-forge session-start hook — slim, just announces availability.
#
# Outputs an additionalContext informing the model team-forge is installed
# and what its entry points are. No enforcement bravado.

set -euo pipefail

message='team-forge extension is installed.

Available skills:
  - team-forge-brainstorming    (Phase 1 — agent-team-aware brainstorming with active interrogation)
  - team-forge-writing-plans    (Phase 2 — high-level milestone planning with hard-dependency interrogation)
  - team-forge-design           (Phase 3 — multi-agent design pattern producing design.yaml)
  - team-forge-forge            (Phase 4 — emit agent .md files + launcher skill + dashboard from design.yaml)
  - team-forge-rehydrate        (/resume protocol — lead reads tracker + KB, respawns teammates)
  - team-forge-tracker          (tracker-role pattern for forged teams)
  - team-forge-monitor          (monitor-role pattern for forged teams)

To forge a new project team: ask Claude to "use team-forge to design an agent team for <project>".
To launch an already-forged team: invoke /<team>-team (e.g. /herc-team).

Requires CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1 in your settings.'

# Escape for JSON
escaped=$(printf '%s' "$message" | python3 -c 'import json, sys; print(json.dumps(sys.stdin.read()))')

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{"hookSpecificOutput":{"additionalContext":%s}}\n' "$escaped"
else
  printf '{"additional_context":%s}\n' "$escaped"
fi
