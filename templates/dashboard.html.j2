<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>team-forge dashboard</title>
<style>
:root {
  --ivory: #FAF9F5; --slate: #141413; --clay: #D97757; --oat: #E3DACC;
  --olive: #788C5D; --rust: #B04A3F; --gray-150: #F0EEE6; --gray-300: #D1CFC5;
  --gray-500: #87867F; --gray-700: #3D3D3A; --white: #FFFFFF;
  --serif: ui-serif, Georgia, serif; --sans: system-ui, sans-serif;
  --mono: ui-monospace, Menlo, monospace;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: var(--sans); background: var(--ivory); color: var(--gray-700); line-height: 1.55; }
.shell { display: grid; grid-template-columns: 212px minmax(0, 1fr); max-width: 1320px; margin: 0 auto; gap: 36px; padding: 0 32px 130px; }

/* nav / scroll-spy TOC */
nav.toc { position: sticky; top: 0; align-self: start; height: 100vh; padding: 40px 0; overflow-y: auto; }
.toc .brand { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gray-500); margin-bottom: 16px; padding: 0 10px; }
.toc a { display: block; font-size: 13px; color: var(--gray-500); text-decoration: none; padding: 6px 10px; border-left: 2px solid transparent; border-radius: 0 6px 6px 0; transition: 0.15s; }
.toc a:hover { color: var(--slate); background: var(--gray-150); }
.toc a.active { color: var(--clay); border-left-color: var(--clay); background: var(--gray-150); font-weight: 600; }

main { padding-top: 40px; min-width: 0; }
.eyebrow { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gray-500); margin-bottom: 8px; }
h1 { font-family: var(--serif); font-size: 32px; font-weight: 500; color: var(--slate); margin-bottom: 6px; }
.subtitle { font-size: 14px; color: var(--gray-500); margin-bottom: 28px; }
.subtitle code { font-family: var(--mono); background: var(--gray-150); padding: 1px 6px; border-radius: 4px; }

.stat-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 32px; }
.stat-cell { background: var(--white); border: 1.5px solid var(--gray-300); border-radius: 12px; padding: 16px 18px; }
.stat-label { font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gray-500); margin-bottom: 6px; }
.stat-value { font-family: var(--serif); font-size: 22px; color: var(--slate); font-weight: 500; }
.stat-value.accent { color: var(--clay); }

.panel { background: var(--white); border: 1.5px solid var(--gray-300); border-radius: 12px; margin-bottom: 20px; overflow: hidden; }
.panel-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 15px 20px; cursor: pointer; }
.panel-head .pt { display: flex; align-items: baseline; gap: 10px; }
.panel-head h2 { font-family: var(--serif); font-size: 17px; font-weight: 500; color: var(--slate); }
.panel-head .count { font-family: var(--mono); font-size: 11px; color: var(--gray-500); }
.caret { font-family: var(--mono); color: var(--gray-500); font-size: 12px; transition: transform 0.15s; }
.panel.collapsed .caret { transform: rotate(-90deg); }
.panel-body { padding: 0 20px 18px; }
.panel.collapsed .panel-body { display: none; }

.controls { display: flex; gap: 8px; flex-wrap: wrap; margin: 2px 0 14px; }
.chip { font-family: var(--mono); font-size: 11px; padding: 3px 10px; border-radius: 20px; border: 1px solid var(--gray-300); background: var(--white); color: var(--gray-500); cursor: pointer; user-select: none; }
.chip.on { background: var(--slate); color: var(--white); border-color: var(--slate); }

.pill { display: inline-block; font-family: var(--mono); font-size: 11px; padding: 3px 10px; border-radius: 12px; font-weight: 600; }
.pill.running { background: var(--clay); color: var(--white); }
.pill.completed { background: var(--olive); color: var(--white); }
.pill.pending { background: var(--gray-300); color: var(--gray-700); }
.pill.failed { background: var(--rust); color: var(--white); }
.pill.waiting { background: var(--oat); color: var(--slate); }
.pill.idle { background: var(--gray-150); color: var(--gray-500); }
.pill.initial { background: var(--oat); color: var(--slate); }

.role-tag { font-family: var(--mono); font-size: 10px; padding: 2px 6px; border-radius: 4px; }
.role-tag.work { background: var(--gray-150); color: var(--gray-700); }
.role-tag.verify { background: #E8EFE0; color: var(--olive); }
.role-tag.advise { background: #F3D9CC; color: #8A3B1E; }
.role-tag.tracker { background: var(--oat); color: var(--slate); }
.role-tag.monitor { background: #FDF3EE; color: var(--clay); }
.role-tag.orchestrator { background: var(--clay); color: var(--white); }

table.grid { width: 100%; border-collapse: collapse; }
table.grid th { text-align: left; font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--gray-500); padding: 6px 8px; border-bottom: 1.5px solid var(--gray-300); cursor: pointer; user-select: none; white-space: nowrap; }
table.grid td { padding: 9px 8px; border-bottom: 1px solid var(--gray-150); font-size: 13px; vertical-align: top; }
table.grid tr:last-child td { border-bottom: none; }
table.grid tr.clickable { cursor: pointer; }
table.grid tr.clickable:hover td { background: var(--gray-150); }
.mono { font-family: var(--mono); font-size: 12px; color: var(--slate); }

.kv { display: flex; justify-content: space-between; gap: 16px; padding: 8px 0; border-bottom: 1px solid var(--gray-150); font-size: 13px; cursor: pointer; }
.kv:last-child { border-bottom: none; }
.kv:hover { background: var(--gray-150); }
.kv .k { color: var(--gray-500); }
.kv .v { font-family: var(--mono); font-size: 12px; color: var(--slate); text-align: right; word-break: break-all; }

.stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
.stat-box { text-align: center; background: var(--gray-150); border-radius: 10px; padding: 12px 8px; cursor: pointer; }
.stat-box:hover { outline: 1.5px solid var(--clay); }
.stat-box .num { font-family: var(--serif); font-size: 26px; color: var(--slate); }
.stat-box .lbl { font-family: var(--mono); font-size: 10px; text-transform: uppercase; color: var(--gray-500); margin-top: 2px; }

.timeline { display: flex; flex-direction: column; gap: 12px; }
.milestone-row { display: grid; grid-template-columns: 120px 1fr; gap: 14px; align-items: start; padding: 6px; border-radius: 8px; cursor: pointer; }
.milestone-row:hover { background: var(--gray-150); }
.milestone-label { font-family: var(--mono); font-size: 11px; color: var(--gray-500); padding-top: 4px; }
.ms-name { font-family: var(--serif); font-size: 15px; color: var(--slate); margin-bottom: 4px; }
.ms-desc { font-size: 12.5px; color: var(--gray-500); }

.event-row { padding: 9px 4px; border-bottom: 1px solid var(--gray-150); cursor: pointer; }
.event-row:last-child { border-bottom: none; }
.event-row:hover { background: var(--gray-150); }
.event-meta { font-family: var(--mono); font-size: 10px; color: var(--gray-500); }
.event-line { margin-top: 2px; font-size: 13px; }
.event-line strong { color: var(--slate); }
.event-detail { display: none; margin-top: 6px; font-size: 12.5px; color: var(--gray-700); white-space: pre-wrap; }
.event-row.open .event-detail { display: block; }

.empty-state { text-align: center; padding: 32px 20px; color: var(--gray-500); font-size: 14px; font-style: italic; }

.footer-note { margin-top: 44px; padding-top: 18px; border-top: 1px solid var(--gray-300); font-family: var(--mono); font-size: 11px; color: var(--gray-500); display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }

.prompt-footer { position: fixed; bottom: 0; left: 0; right: 0; background: var(--ivory); border-top: 1.5px solid var(--gray-300); display: flex; align-items: center; gap: 14px; padding: 13px 28px; z-index: 50; }
.prompt-footer .label { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gray-500); }
.prompt-footer .text { flex: 1; font-size: 13.5px; color: var(--gray-700); font-style: italic; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.prompt-footer .text.empty { color: var(--gray-500); }
.prompt-footer .copy-btn { background: var(--clay); color: var(--white); border: none; font-family: var(--sans); font-size: 13px; padding: 7px 16px; border-radius: 8px; cursor: pointer; }
.prompt-footer .copy-btn:disabled { background: var(--gray-300); color: var(--gray-500); cursor: default; }

.noscript-note { max-width: 760px; margin: 60px auto; padding: 28px 32px; background: var(--white); border: 1.5px solid var(--gray-300); border-radius: 12px; }
.noscript-note h1 { font-size: 22px; margin-bottom: 10px; }

@media (max-width: 860px) {
  .shell { grid-template-columns: 1fr; gap: 0; }
  nav.toc { display: none; }
  .stat-strip { grid-template-columns: 1fr 1fr; }
}
</style>
</head>
<body>
<noscript>
  <div class="noscript-note">
    <h1>team-forge dashboard</h1>
    <p>This dashboard renders its panels with a small embedded script. Enable
    JavaScript to view it, or read the raw state at <code>tracker/status.json</code>.</p>
  </div>
</noscript>

<div class="shell" id="shell" hidden>
  <nav class="toc"><div class="brand">team-forge</div><div id="toc"></div></nav>
  <main>
    <div class="eyebrow" id="eyebrow">team-forge dashboard</div>
    <h1 id="title">—</h1>
    <div class="subtitle" id="subtitle"></div>
    <div class="stat-strip" id="stat-strip"></div>
    <div id="panels"></div>
    <div class="footer-note">
      <div id="foot-left">Generated by team-forge · single-writer</div>
      <div id="foot-right"></div>
    </div>
  </main>
</div>

<div class="prompt-footer">
  <span class="label">Prompt</span>
  <span class="text empty" id="prompt-text">Click any panel, row, milestone, or event to build a focused prompt about it.</span>
  <button class="copy-btn" id="copy-btn" onclick="copyPrompt()" disabled>Copy</button>
</div>

<script>
// ── The single source of state. The writer (monitor agent or gen_dashboard.py)
// replaces the slot below with the JSON payload built from tracker/status.json.
const DASHBOARD_DATA = {{DASHBOARD_DATA_JSON}};

(function () {
  const D = DASHBOARD_DATA || {};
  const meta = D.meta || {};
  const team = meta.team || "team";

  // ── tiny DOM helper ───────────────────────────────────────────────
  function el(tag, attrs) {
    const n = document.createElement(tag);
    if (attrs) for (const k in attrs) {
      if (k === "class") n.className = attrs[k];
      else if (k === "colspan") n.colSpan = attrs[k];
      else n.setAttribute(k, attrs[k]);
    }
    for (let i = 2; i < arguments.length; i++) {
      const c = arguments[i];
      if (c == null) continue;
      n.appendChild(typeof c === "object" ? c : document.createTextNode(String(c)));
    }
    return n;
  }
  function short(s, n) { s = s == null ? "" : String(s); return s.length > (n || 9) ? s.slice(0, n || 9) : s; }

  // ── status → pill class (unifies team + workflow vocabularies) ─────
  const PILL = { done: "completed", completed: "completed", in_progress: "running",
    running: "running", blocked: "failed", failed: "failed", pending: "pending",
    waiting: "waiting", idle: "idle", initial: "initial" };
  function pill(s) { return el("span", { class: "pill " + (PILL[String(s)] || "idle") }, s == null ? "—" : String(s)); }

  // ── prompt footer ─────────────────────────────────────────────────
  const promptEl = document.getElementById("prompt-text");
  const copyBtn = document.getElementById("copy-btn");
  let current = "";
  function setPrompt(t) {
    current = t; promptEl.textContent = t;
    promptEl.classList.remove("empty"); copyBtn.disabled = false;
  }
  window.copyPrompt = function () {
    if (!current) return;
    navigator.clipboard.writeText(current).then(function () {
      copyBtn.textContent = "Copied!";
      setTimeout(function () { copyBtn.textContent = "Copy"; }, 1500);
    });
  };
  function promptFor(kind, x) {
    switch (kind) {
      case "task": return "In the " + team + " workflow, task `" + x.id + "` is " + x.status +
        (x.gate_status ? " (gate: " + x.gate_status + ")" : "") + ". " +
        (String(x.status) === "blocked" ? "What's blocking it and what's the smallest next step to unblock it?"
          : "Summarize where it stands and what's left.");
      case "agent": return "In the " + team + " team, teammate `" + x.name + "` (" + x.role +
        ") is " + (x.status || "idle") + ". What does it own right now?";
      case "milestone": return "Explain milestone `" + x.id + "` (" + x.name + ") in the " + team +
        " team — its output and go/no-go criterion, and how close it is to done.";
      case "event": return "Expand on this " + team + " event — " + x.kind + " by " + (x.actor || "?") +
        ": " + (x.summary || "") + ". What led to it and what happens next?";
      case "ticket": return "Ticket #" + x.issue + " (" + x.type + ", route " + x.route + ") is at stage " +
        x.stage + ". What's its status and the next action?";
      case "gate": return "Gate `" + x.gate + "` on task `" + x.task + "` " + (x.passed ? "passed" : "failed") +
        ". " + (x.passed ? "" : "Why did it fail and how do we get it green?");
      case "branch": return "Integration branch `" + (x.name || "—") + "` (head " + short(x.head_sha) +
        ") — what's its state and is it ready for review?";
      case "queue": return "The " + team + " queue has " + x.count + " item(s) in the " + x.label +
        " bucket. What's in it and what's the next move?";
      case "pointer": return "Open the current " + x.label + " for the " + team + " team (" + x.value +
        ") and summarize where it landed.";
      case "panel": return "Walk me through the \"" + x + "\" panel of the " + team + " dashboard.";
    }
    return "";
  }

  // ── generic sortable / filterable table ───────────────────────────
  // cols: [{key, label, mono?, cell?(row)->node, sortVal?(row)}]
  function dataTable(opts) {
    const rows = opts.rows || [], cols = opts.cols, statusKey = opts.statusKey, kind = opts.kind;
    let sortKey = null, sortDir = 1, active = null;
    const wrap = el("div");

    if (statusKey) {
      const statuses = Array.from(new Set(rows.map(function (r) { return String(r[statusKey] == null ? "" : r[statusKey]); }))).filter(Boolean);
      if (statuses.length > 1) {
        active = new Set(statuses);
        const bar = el("div", { class: "controls" });
        statuses.forEach(function (s) {
          const c = el("span", { class: "chip on" }, s);
          c.onclick = function (e) {
            e.stopPropagation();
            if (active.has(s)) { active.delete(s); c.classList.remove("on"); }
            else { active.add(s); c.classList.add("on"); }
            draw();
          };
          bar.appendChild(c);
        });
        wrap.appendChild(bar);
      }
    }

    const tbl = el("table", { class: "grid" });
    const head = el("tr");
    cols.forEach(function (col) {
      const th = el("th", {}, col.label);
      const arr = el("span", { class: "arrow" }, "");
      th.appendChild(arr);
      th.onclick = function (e) {
        e.stopPropagation();
        if (sortKey === col.key) sortDir *= -1; else { sortKey = col.key; sortDir = 1; }
        draw();
      };
      head.appendChild(th);
    });
    tbl.appendChild(head);
    const body = el("tbody");
    tbl.appendChild(body);
    wrap.appendChild(tbl);

    function draw() {
      Array.prototype.forEach.call(head.children, function (th, i) {
        th.querySelector(".arrow").textContent = cols[i].key === sortKey ? (sortDir > 0 ? "  ↑" : "  ↓") : "";
      });
      let r = rows.slice();
      if (statusKey && active) r = r.filter(function (x) { return active.has(String(x[statusKey] == null ? "" : x[statusKey])); });
      if (sortKey) {
        const col = cols.filter(function (c) { return c.key === sortKey; })[0];
        r.sort(function (a, b) {
          const va = (col.sortVal ? col.sortVal(a) : a[sortKey]); const vb = (col.sortVal ? col.sortVal(b) : b[sortKey]);
          const xa = va == null ? "" : va, xb = vb == null ? "" : vb;
          return (xa > xb ? 1 : xa < xb ? -1 : 0) * sortDir;
        });
      }
      body.textContent = "";
      if (!r.length) {
        body.appendChild(el("tr", {}, el("td", { colspan: cols.length, class: "empty-state" }, "Nothing to show.")));
        return;
      }
      r.forEach(function (row) {
        const tr = el("tr", { class: kind ? "clickable" : "" });
        cols.forEach(function (col) {
          const td = el("td", col.mono ? { class: "mono" } : {});
          const c = col.cell ? col.cell(row) : (row[col.key] == null ? "—" : row[col.key]);
          td.appendChild(typeof c === "object" ? c : document.createTextNode(String(c)));
          tr.appendChild(td);
        });
        if (kind) tr.onclick = function () { setPrompt(promptFor(kind, row)); };
        body.appendChild(tr);
      });
    }
    draw();
    return wrap;
  }

  function emptyState(msg) { return el("div", { class: "empty-state" }, msg); }

  // ── panel renderers (return {node, count}) ────────────────────────
  const RENDER = {
    milestone_timeline: function (d) {
      const ms = d.milestones || [];
      if (!ms.length) return { node: emptyState("No milestones defined."), count: 0 };
      const tl = el("div", { class: "timeline" });
      ms.forEach(function (m) {
        const row = el("div", { class: "milestone-row" },
          el("div", { class: "milestone-label" }, m.id),
          el("div", {},
            el("div", { class: "ms-name" }, (m.name || m.id) + "  ", pill(m.status || "pending")),
            el("div", { class: "ms-desc" }, m.output || "")));
        row.onclick = function () { setPrompt(promptFor("milestone", m)); };
        tl.appendChild(row);
      });
      return { node: tl, count: ms.length };
    },
    team_roster_and_status: function (d) {
      const r = d.roster || [];
      return {
        count: r.length, node: dataTable({
          rows: r, kind: "agent", statusKey: "status", cols: [
            { key: "name", label: "teammate", mono: true },
            { key: "role", label: "role", cell: function (x) { return el("span", { class: "role-tag " + x.role }, x.role); } },
            { key: "status", label: "status", cell: function (x) { return pill(x.status || "idle"); } }]
        })
      };
    },
    current_pointers: function (d) {
      const p = d.pointers || {};
      const items = [["brainstorm", p.brainstorm], ["team plan", p.team_plan]];
      const box = el("div");
      items.forEach(function (it) {
        const row = el("div", { class: "kv" }, el("span", { class: "k" }, it[0]), el("span", { class: "v" }, it[1] || "—"));
        if (it[1]) row.onclick = function () { setPrompt(promptFor("pointer", { label: it[0], value: it[1] })); };
        box.appendChild(row);
      });
      return { node: box, count: 0 };
    },
    recent_events: function (d) {
      const ev = (d.events || []).slice().reverse();
      if (!ev.length) return { node: emptyState("No events yet."), count: 0 };
      const box = el("div");
      ev.forEach(function (e) {
        const row = el("div", { class: "event-row" },
          el("div", { class: "event-meta" }, (e.ts || "").slice(0, 19) + (e.actor ? " · " + e.actor : "")),
          el("div", { class: "event-line" }, el("strong", {}, e.kind || ""), e.summary ? " — " + e.summary : ""),
          el("div", { class: "event-detail" }, e.summary || e.kind || ""));
        row.onclick = function () { row.classList.toggle("open"); setPrompt(promptFor("event", e)); };
        box.appendChild(row);
      });
      return { node: box, count: ev.length };
    },
    task_timeline: function (d) {
      const t = d.tasks || [];
      return {
        count: t.length, node: dataTable({
          rows: t, kind: "task", statusKey: "status", cols: [
            { key: "id", label: "task", mono: true },
            { key: "status", label: "status", cell: function (x) { return pill(x.status || "pending"); } },
            { key: "gate_status", label: "gate" },
            { key: "commit", label: "commit", mono: true, cell: function (x) { return short(x.commit) || "—"; } }]
        })
      };
    },
    gate_matrix: function (d) {
      const g = (d.gate_results || []).map(function (x) { return Object.assign({}, x, { _r: x.passed ? "passed" : "failed" }); });
      return {
        count: g.length, node: dataTable({
          rows: g, kind: "gate", statusKey: "_r", cols: [
            { key: "task", label: "task", mono: true },
            { key: "gate", label: "gate", mono: true },
            { key: "_r", label: "result", cell: function (x) { return pill(x.passed ? "done" : "blocked"); } }]
        })
      };
    },
    integration_branch_status: function (d) {
      const b = d.integration_branch || {};
      const rows = [["branch", b.name], ["head", short(b.head_sha)], ["PR", b.pr_url]];
      const box = el("div");
      rows.forEach(function (it) {
        box.appendChild(el("div", { class: "kv" }, el("span", { class: "k" }, it[0]), el("span", { class: "v" }, it[1] || "—")));
      });
      box.onclick = function () { setPrompt(promptFor("branch", b)); };
      return { node: box, count: 0 };
    },
    queue_state: function (d) {
      const q = d.queue || {};
      const defs = [["eligible", "eligible"], ["full_drain", "full-drain"], ["plan_gate", "plan-gate"],
        ["in_flight", "in-flight"], ["pr_ready", "pr-ready"], ["blocked", "blocked"]];
      const grid = el("div", { class: "stats" });
      defs.forEach(function (it) {
        const n = q[it[0]] || 0;
        const box = el("div", { class: "stat-box" }, el("div", { class: "num" }, n), el("div", { class: "lbl" }, it[1]));
        box.onclick = function () { setPrompt(promptFor("queue", { count: n, label: it[1] })); };
        grid.appendChild(box);
      });
      return { node: grid, count: 0 };
    },
    ticket_table: function (d) {
      const t = d.tickets || [];
      return {
        count: t.length, node: dataTable({
          rows: t, kind: "ticket", statusKey: "stage", cols: [
            { key: "issue", label: "issue", mono: true, cell: function (x) { return "#" + x.issue; } },
            { key: "type", label: "type" },
            { key: "route", label: "route" },
            { key: "stage", label: "stage", cell: function (x) { return pill(x.stage || "pending"); } },
            { key: "pr_url", label: "PR", mono: true, cell: function (x) { return x.pr_url || "—"; } }]
        })
      };
    }
  };

  const TITLES = {
    milestone_timeline: "Milestone timeline", team_roster_and_status: "Team roster",
    current_pointers: "Current pointers", recent_events: "Recent events",
    task_timeline: "Task timeline", gate_matrix: "Gate matrix",
    integration_branch_status: "Integration branch", queue_state: "Queue", ticket_table: "Tickets"
  };

  // ── header ────────────────────────────────────────────────────────
  document.title = team + " — " + (meta.project_display_name || "") + " · team-forge dashboard";
  document.getElementById("eyebrow").textContent = "team-forge dashboard · " + (meta.project_basename || team);
  document.getElementById("title").textContent = team + " — " + (meta.project_display_name || "");
  const sub = document.getElementById("subtitle");
  sub.appendChild(document.createTextNode("Domain: "));
  sub.appendChild(el("code", {}, meta.domain || "—"));
  sub.appendChild(document.createTextNode("  ·  " + (meta.archetype === "workflow" ? "rendered by gen_dashboard.py" : "monitor agent writes this file")));
  document.getElementById("foot-right").textContent = "Last update: " + (meta.last_update_iso || "—");

  const focusLabel = meta.archetype === "workflow" ? "Task" : "Milestone";
  const focusVal = (meta.archetype === "workflow" ? meta.current_task : meta.current_milestone) || "—";
  const strip = document.getElementById("stat-strip");
  [["Status", el("span", { class: "pill " + (PILL[String(meta.overall_status)] || "initial") }, meta.overall_status || "initial"), false],
   [focusLabel, focusVal, true],
   ["Token spend", (meta.token_spend_cumulative_k || 0) + "k", false],
   [meta.archetype === "workflow" ? "Archetype" : "Cohort", (meta.archetype === "workflow" ? "workflow" : (meta.current_cohort_id || "—")), false]
  ].forEach(function (it) {
    const v = el("div", { class: "stat-value" + (it[2] ? " accent" : "") });
    v.appendChild(typeof it[1] === "object" ? it[1] : document.createTextNode(String(it[1])));
    strip.appendChild(el("div", { class: "stat-cell" }, el("div", { class: "stat-label" }, it[0]), v));
  });

  // ── panels + TOC ──────────────────────────────────────────────────
  const panelHost = document.getElementById("panels");
  const toc = document.getElementById("toc");
  const panels = (D.panels && D.panels.length) ? D.panels : Object.keys(TITLES);
  const sections = [];

  panels.forEach(function (id) {
    const title = TITLES[id] || id.replace(/_/g, " ").replace(/\b\w/g, function (c) { return c.toUpperCase(); });
    const r = RENDER[id] ? RENDER[id](D) : { node: emptyState("No renderer for this panel — awaiting data from tracker."), count: 0 };
    const sec = el("section", { class: "panel", id: "p-" + id });
    const head = el("div", { class: "panel-head" },
      el("div", { class: "pt" }, el("h2", {}, title), r.count ? el("span", { class: "count" }, r.count) : null),
      el("span", { class: "caret" }, "▾"));
    head.onclick = function () { sec.classList.toggle("collapsed"); };
    const bodyWrap = el("div", { class: "panel-body" }, r.node);
    sec.appendChild(head); sec.appendChild(bodyWrap);
    panelHost.appendChild(sec);
    sections.push(id);
    toc.appendChild(el("a", { href: "#p-" + id }, title));
  });

  document.getElementById("shell").hidden = false;

  // ── scroll-spy ────────────────────────────────────────────────────
  const links = Array.prototype.slice.call(toc.querySelectorAll("a"));
  const io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        const id = e.target.id;
        links.forEach(function (l) { l.classList.toggle("active", l.getAttribute("href") === "#" + id); });
      }
    });
  }, { rootMargin: "-8% 0px -82% 0px" });
  sections.forEach(function (id) { const s = document.getElementById("p-" + id); if (s) io.observe(s); });
})();
</script>
</body>
</html>
