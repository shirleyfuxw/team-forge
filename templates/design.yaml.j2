# team-forge / Phase 3 — design.yaml
# ============================================================================
#
# This file is the contract between Phase 3 (Design) and Phase 4 (Forge).
# Phase 3's forge-design-agents PRODUCE this file (in parallel; human approves).
# Phase 4 (team-forge:forge) READS it and emits .md files, launcher skill,
# tracker initial state, dashboard initial render, and KB scaffolds.
#
# This is NOT a Jinja2 template. It is the SCHEMA REFERENCE for what Phase 3
# must produce. Forge-design-agents write the actual design.yaml from scratch
# following this schema. Comments document each field's purpose, type, and
# enum values.
#
# Universal validation Phase 3 MUST satisfy:
#   ROLE COVERAGE      — at least one teammate per role: work, verify, advise
#                        (+ exactly one orchestrator). tracker and monitor are
#                        OPTIONAL: the default is a lead-written ledger + a
#                        deterministic dashboard render step (gen_dashboard.py,
#                        as in the workflow archetype); add them only when the
#                        tracking load justifies standing agents. Combined roles
#                        allowed via `combined_roles: [...]` on a teammate.
#   COMMS CLOSURE      — every roster reference in `tracking.state_shape[].source`
#                        and `constraints[]` must exist in `roster` or be "lead".
#   SHARED-AGENT NAMING — entries with `shared_across_teams: true` keep unprefixed
#                        names; non-shared get prefixed `<team>-<name>` at Forge.
#
# SUBAGENT MEMORY (native — usually no field to set): Forge relies on Claude Code's
# native per-agent memory. DISPATCHED roles (advise; workflow worker/advisor) are
# emitted with `memory: project` frontmatter → a private `.claude/agent-memory/<name>/`
# directory whose MEMORY.md Claude Code auto-injects and the agent self-curates
# (patterns, gotchas, ruled-out approaches) across dispatches. Standing TEAMMATES
# (work/verify/tracker/monitor) get none — Claude Code ignores `memory:` on the
# teammate path; their durable context is this KB + the shared task list, so the lead
# hands each a scoped brief. To override a role's scope, set `memory: user|project|local`
# on its roster entry (default: project for dispatched roles, omitted otherwise). The
# lead does NOT harvest agent memory — there is no team-level memory store.
# ============================================================================

# ----------------------------------------------------------------------------
# project — identity + the 1-paragraph brief (from Phase 1 brainstorm).
# ----------------------------------------------------------------------------
project:
  name: <slug>                              # team prefix; lowercase + hyphens; required
  display_name: "<human-friendly name>"     # required
  target_repo: "/absolute/path/to/repo"     # required; absolute path
  target_repo_basename: <basename>          # OPTIONAL; display-only label (dashboard eyebrow).
                                            # NEVER a durable-path component — durable artifacts
                                            # live at docs/team-forge/<team>/ with no repo-name level.
  domain: <enum>                            # quant-research | frontend | ml-research |
                                            # backend-api | data-pipeline | custom
  brief: |
    <one-paragraph brief — verbatim from brainstorm if possible>

# ----------------------------------------------------------------------------
# milestones — Phase 2 output. High-level only (no detail task lists).
# ----------------------------------------------------------------------------
# 2–5 milestones. Each has a verifiable output + an explicit human go/no-go gate.
milestones:
  - id: <descriptive-slug>                   # e.g. post-process-runner, NOT t5/m1 — this id
                                             # becomes the artifacts/<id>/ directory name. Opaque
                                             # phase codes are banned (see Naming discipline, SCOPING.md).
    name: "<human-friendly>"
    output: "<verifiable artifact description>"
    go_no_go: "<explicit human-decidable criterion>"
    expected_team_size: <int>                # Phase 2 prediction
    next_phase_check: "<criterion>"
    hard_dependencies: [<other-milestone-id>, ...]   # may be []
    interface_to_next: |
      <prose: what this milestone hands off to the next>

# ----------------------------------------------------------------------------
# roster — concrete teammate definitions.
# ----------------------------------------------------------------------------
# Required per entry: name, role (or combined_roles), purpose, skills.
# Optional: shared_across_teams (default false), combined_roles, model.
roster:
  - name: <slug>                            # filename without .md
    role: <enum>                            # work | verify | advise | orchestrator (required roles)
                                            # | tracker | monitor (OPTIONAL — see ROLE COVERAGE above)
    # combined_roles: [<role>, <role>]      # OPTIONAL — for one-shot/small teams
    purpose: |
      <prose paragraph describing what this teammate owns>
    # shared_across_teams: true             # OPTIONAL — if reused across project's teams
    skills:                                 # SUGGESTED loadout — see "Skill loadouts" note below
      - <skill-name>
      - team-forge:<bare-name>
      - <plugin>:<skill>
    model: <enum>                           # OPTIONAL — sonnet | opus | haiku | fable | <full-id> | inherit ; omit → inherit (teammate follows the lead)

# Skill loadouts note: Per Claude Code's agent-teams primitive, teammates load ALL project +
# user skills regardless of frontmatter declaration — the `skills:` and `mcpServers:` fields
# are NOT applied to a teammate. So the `skills:` field here is advisory documentation of
# intent, not runtime enforcement. NOTE: `tools`, `disallowedTools`, and `model` frontmatter
# ARE honored per-teammate — only `skills`/`mcpServers` are ignored.

# ----------------------------------------------------------------------------
# rehydrate — what the lead reads on /resume.
# ----------------------------------------------------------------------------
# Paths use universal team-forge layout — these are derivation rules, not
# runtime contract. The team-launcher skill body encodes the convention.
rehydrate:
  durable_state:
    - .claude/team-forge/<team>/tracker/status.json
    - docs/team-forge/<team>/brainstorms/<current>.md
    - docs/team-forge/<team>/team-plans/<current>.md
    - docs/team-forge/<team>/artifacts/<milestone-id>/*.md
    - docs/team-forge/<team>/runtime/<milestone-id>/*.md   # optional
  respawn_order: [<roles-in-order>]         # IF the roster has a tracker it MUST be first
                                            # (rehydrate source of truth); a monitor MUST be
                                            # last (depends on others). Without them the lead
                                            # reads status.json directly — no special ordering.

# ----------------------------------------------------------------------------
# tracking — per-project end-to-end tracking spec.
# ----------------------------------------------------------------------------
# The ledger owner maintains status.json per state_shape — the tracker teammate if the
# roster has one, otherwise the lead. dashboard_panels drive the shell render — written
# by the monitor teammate if present, otherwise by the emitted gen_dashboard.py render
# step. Phase 4 emits the initial status.json + rendered dashboard.html either way.
tracking:
  state_shape:                              # fields in tracker/status.json
    - id: <field-name>
      type: <enum>                          # string | int | float | bool | list | object
      source: <agent-name | "lead">         # who reports it — must exist in roster or be "lead"
      description: "<one-line>"
  events_to_log:                            # enum of allowed kinds appended to status.json.events[]
    - milestone_started
    - milestone_completed
    - cohort_started                        # optional — for iterative milestones
    - cohort_completed
    - verifier_verdict
    - agent_blocked
    - brainstorm_revised
    - team_plan_revised
    - rehydrate
    - <domain-specific>
  dashboard_panels:                         # the dashboard shell renders these, in order
    - milestone_timeline
    - team_roster_and_status
    - current_pointers                      # current brainstorm + team-plan
    - recent_events
    # ENFORCED REGISTRY — every entry must be a renderer id the shell ships:
    # milestone_timeline, team_roster_and_status, current_pointers, recent_events (team)
    # + task_timeline, gate_matrix, integration_branch_status, queue_state, ticket_table
    # (workflow). forge.py ABORTS on any other string. Do NOT write prose panel
    # descriptions here — an unknown id used to render a healthy-looking page whose panel
    # stayed an empty placeholder forever (the alpha-onboarding-completeness run shipped
    # four of those for a week). Describe panel *intent* in a comment next to the id;
    # a panel wanting a renderer that doesn't exist yet is a shell change, not a list entry.

# ----------------------------------------------------------------------------
# constraints — project-specific facts the forge agent can't infer.
# ----------------------------------------------------------------------------
constraints:
  - "<free-form constraint sentence>"
  - "<another>"

# ----------------------------------------------------------------------------
# reference_libraries — external curated corpora to mine during asset discovery.
# ----------------------------------------------------------------------------
# OPTIONAL. Local clones of agent/skill libraries the design phase reads as PRIOR
# ART to adapt (reference-and-adapt mode) — NOT installed runtime dependencies.
# Discovery reads the local path; it never fetches over the network during design.
reference_libraries:
  # By NAME — resolves to team-forge's pinned manifest reference-libraries/<name>.yaml
  # (repo URL + pinned commit). Discovery fetches the pinned commit on demand into a
  # local cache via tools/fetch_reference.py; never vendored, never loaded as skills.
  # team-forge ships the `ecc` pin (consumption: reference-and-adapt).
  - ecc
  # Or an ad-hoc library you manage yourself (local clone you keep current):
  # - { name: mylib, path: /abs/path/to/clone, agents_dir: agents, skills_dir: skills }

# ----------------------------------------------------------------------------
# asset_discovery — Phase 3 audit trail (skills AND agents).
# ----------------------------------------------------------------------------
# Logged for human review + future reference. Domain-filtered against project.domain.
asset_discovery:
  domain_filter: <project.domain>            # what the catalog was filtered to

  discovered_skills:
    project_local: [<skill-name>]            # <target_repo>/.claude/skills/
    user_global:   [<skill-name>]            # ~/.claude/skills/
    plugins:
      team-forge: [brainstorming, design, forge, rehydrate, tracker, monitor, writing-plans]
      # superpowers: [...]
    reference_libraries:                     # domain-matched skills from reference libs
      ecc: [<skill-name>]                    # e.g. frontend-patterns, e2e-testing

  discovered_agents:
    project_local: [<agent-name>]            # <target_repo>/.claude/agents/
    user_global:   [<agent-name>]            # ~/.claude/agents/
    plugins:       {}                        # plugin agents by plugin name
    reference_libraries:                     # domain-matched agents from reference libs
      ecc: [<agent-name>]                    # e.g. code-reviewer, architect, tdd-guide

  # The four buckets the design agents act on:
  reuse_candidates:                          # installed, shared/domain-agnostic, domain-match → reference, don't re-emit
    - name: <agent-or-skill>
      source: <project_local | user_global | plugin>
      why: "<shared_across_teams + domain match>"
  adapt_candidates:                          # reference-library prior art → forge our own, cite the source
    - name: <ecc-agent-or-skill>
      source: ecc
      adapt_into: <new-roster-entry-name>
      borrowed: "<what pattern we took>"
  collision_list: [<existing-agent-or-skill-name>, ...]   # never emit a clashing name
  pattern_references: [<agent-or-team>, ...]               # role structures that informed the roster

  proposed_loadouts_per_teammate:            # final skills per teammate (also written into roster[].skills)
    <teammate-name>: [<skill>, <skill>]

# ----------------------------------------------------------------------------
# skill_gaps — capabilities NO existing asset covers; the forge PRODUCES these.
# ----------------------------------------------------------------------------
# The complement of asset_discovery: reuse what exists, adapt prior art, FORGE
# what's missing. Produced skills are the forge's primary deliverable — they
# outlive the team (WORKFLOW-SCOPING.md). Phase 4 emits one DRAFT scaffold per
# entry at .claude/team-forge/<team>/skill-drafts/<name>/SKILL.md.
#
# WHY promotion to .claude/skills/<name>/ is a human go/no-go (not automatic):
#   1. The acceptance check CANNOT pass at forge time — for verification gaps
#      the skill's backing artifact doesn't exist yet (the skill is what
#      creates it; e.g. tidy-parity-check's acceptance runs the very harness
#      the skill builds). At emission every draft is definitionally unverified.
#   2. Self-certification is circular — the same process that wrote the skill
#      wrote its acceptance check. Auto-promoting on green would let a
#      too-weak acceptance certify a wrong gate harness: silently-wrong
#      verification, the worst failure mode for a gate-backed skill.
#   3. Promoted skills load into EVERY future session — a skill description is
#      matched against all sessions in the repo; a vague trigger misfires
#      forever. Drafts staged in the hub are invisible until promoted.
# It is the same interaction as every other phase gate (brainstorm, plan,
# design.yaml all end in a human approve/reject): the LEAD does the legwork
# (runs the acceptance check, fills the promotion checklist), the human just
# approves. Until promoted, gates/dispatches that reference the skill
# fail-closed (intentional).
#
# Quality bar Phase 3 must satisfy per entry ("proper skill per project purpose"):
#   ONE capability per skill (not a task note) · trigger-first description
#   ("Use when ...") · a RUNNABLE acceptance check · purpose traceable to
#   project.domain + brief + the brainstorm's verification posture · name not in
#   asset_discovery.collision_list · prior art cited when adapting.
skill_gaps:                                  # OPTIONAL — omit when discovery covered everything
  - name: <kebab-slug>                       # e.g. tidy-parity-check; collision-checked
    kind: <enum>                             # verification | domain-procedure | role-capability
    backing: "<gate-name | role | milestone-id>"   # what invokes this skill
    purpose: |
      <the capability this provides + why no existing asset covers it>
    trigger: "Use when <concrete conditions>"      # becomes the SKILL.md description
    spec: |
      <procedure sketch: inputs, outputs, concrete commands>
    acceptance: "<runnable check proving the skill works>"
    consumers: [<roster-or-profile-name | lead>]
    # adapted_from: <reference-library asset>      # OPTIONAL — cite prior art
