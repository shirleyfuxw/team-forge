# team-forge / Phase 3 — design.yaml
# ============================================================================
#
# This file is the contract between Phase 3 (Design) and Phase 4 (Forge).
# Phase 3's forge-design-agents PRODUCE this file (in parallel; human approves).
# Phase 4 (team-forge:forge) READS it and emits .md files, launcher skill,
# tracker initial state, dashboard initial render, and KB scaffolds.
#
# This is NOT a Jinja2 template. It is the SCHEMA REFERENCE for what Phase 3
# must produce. Forge-design-agents write the actual design.yaml from scratch
# following this schema. Comments document each field's purpose, type, and
# enum values.
#
# Universal validation Phase 3 MUST satisfy:
#   ROLE COVERAGE      — at least one teammate per role: work, verify, advise,
#                        tracker, monitor. Combined roles allowed via
#                        `combined_roles: [...]` on a teammate.
#   COMMS CLOSURE      — every roster reference in `tracking.state_shape[].source`
#                        and `constraints[]` must exist in `roster` or be "lead".
#   SHARED-AGENT NAMING — entries with `shared_across_teams: true` keep unprefixed
#                        names; non-shared get prefixed `<team>-<name>` at Forge.
# ============================================================================

# ----------------------------------------------------------------------------
# project — identity + the 1-paragraph brief (from Phase 1 brainstorm).
# ----------------------------------------------------------------------------
project:
  name: <slug>                              # team prefix; lowercase + hyphens; required
  display_name: "<human-friendly name>"     # required
  target_repo: "/absolute/path/to/repo"     # required; absolute path
  target_repo_basename: <basename>          # OPTIONAL; display-only label (dashboard eyebrow).
                                            # NEVER a durable-path component — durable artifacts
                                            # live at docs/team-forge/<team>/ with no repo-name level.
  domain: <enum>                            # quant-research | frontend | ml-research |
                                            # backend-api | data-pipeline | custom
  brief: |
    <one-paragraph brief — verbatim from brainstorm if possible>

# ----------------------------------------------------------------------------
# milestones — Phase 2 output. High-level only (no detail task lists).
# ----------------------------------------------------------------------------
# 2–5 milestones. Each has a verifiable output + an explicit human go/no-go gate.
milestones:
  - id: <descriptive-slug>                   # e.g. post-process-runner, NOT t5/m1 — this id
                                             # becomes the artifacts/<id>/ directory name. Opaque
                                             # phase codes are banned (see Naming discipline, SCOPING.md).
    name: "<human-friendly>"
    output: "<verifiable artifact description>"
    go_no_go: "<explicit human-decidable criterion>"
    expected_team_size: <int>                # Phase 2 prediction
    next_phase_check: "<criterion>"
    hard_dependencies: [<other-milestone-id>, ...]   # may be []
    interface_to_next: |
      <prose: what this milestone hands off to the next>

# ----------------------------------------------------------------------------
# roster — concrete teammate definitions.
# ----------------------------------------------------------------------------
# Required per entry: name, role (or combined_roles), purpose, skills.
# Optional: shared_across_teams (default false), combined_roles, model.
roster:
  - name: <slug>                            # filename without .md
    role: <enum>                            # work | verify | advise | tracker | monitor | orchestrator
    # combined_roles: [<role>, <role>]      # OPTIONAL — for one-shot/small teams
    purpose: |
      <prose paragraph describing what this teammate owns>
    # shared_across_teams: true             # OPTIONAL — if reused across project's teams
    skills:                                 # SUGGESTED loadout — see "Skill loadouts" note below
      - <skill-name>
      - team-forge:<bare-name>
      - <plugin>:<skill>
    model: <enum>                           # OPTIONAL — opus | sonnet | haiku ; default sonnet

# Skill loadouts note: Per Claude Code's agent-teams primitive, teammates load
# ALL project + user skills regardless of frontmatter declaration. The `skills:`
# field is advisory documentation of intent, not runtime enforcement.

# ----------------------------------------------------------------------------
# rehydrate — what the lead reads on /resume.
# ----------------------------------------------------------------------------
# Paths use universal team-forge layout — these are derivation rules, not
# runtime contract. The team-launcher skill body encodes the convention.
rehydrate:
  durable_state:
    - .claude/team-forge/<team>/tracker/status.json
    - docs/team-forge/<team>/brainstorms/<current>.md
    - docs/team-forge/<team>/team-plans/<current>.md
    - docs/team-forge/<team>/artifacts/<milestone-id>/*.md
    - docs/team-forge/<team>/runtime/<milestone-id>/*.md   # optional
  respawn_order: [tracker, <other-roles-in-order>, monitor]
                                            # tracker MUST be first (rehydrate source of truth)
                                            # monitor MUST be last (depends on others being up)

# ----------------------------------------------------------------------------
# tracking — per-project end-to-end tracking spec.
# ----------------------------------------------------------------------------
# Tracker agent reads this at runtime. Monitor agent reads dashboard_panels.
# Phase 4 emits initial empty status.json from state_shape + initial rendered
# dashboard.html from dashboard_panels.
tracking:
  state_shape:                              # fields in tracker/status.json
    - id: <field-name>
      type: <enum>                          # string | int | float | bool | list | object
      source: <agent-name | "lead">         # who reports it — must exist in roster or be "lead"
      description: "<one-line>"
  events_to_log:                            # enum of allowed kinds appended to status.json.events[]
    - milestone_started
    - milestone_completed
    - cohort_started                        # optional — for iterative milestones
    - cohort_completed
    - verifier_verdict
    - agent_blocked
    - brainstorm_revised
    - team_plan_revised
    - rehydrate
    - <domain-specific>
  dashboard_panels:                         # the dashboard shell renders these, in order
    - milestone_timeline
    - team_roster_and_status
    - current_pointers                      # current brainstorm + team-plan
    - recent_events
    # The self-contained shell ships ONE renderer shared by both archetypes. Its panel
    # registry covers: milestone_timeline, team_roster_and_status, current_pointers,
    # recent_events (team) + task_timeline, gate_matrix, integration_branch_status,
    # queue_state, ticket_table (workflow). Any other id renders a labeled empty-state —
    # safe to list a <domain-specific> panel before a renderer exists for it.
    - <domain-specific>

# ----------------------------------------------------------------------------
# constraints — project-specific facts the forge agent can't infer.
# ----------------------------------------------------------------------------
constraints:
  - "<free-form constraint sentence>"
  - "<another>"

# ----------------------------------------------------------------------------
# reference_libraries — external curated corpora to mine during asset discovery.
# ----------------------------------------------------------------------------
# OPTIONAL. Local clones of agent/skill libraries the design phase reads as PRIOR
# ART to adapt (reference-and-adapt mode) — NOT installed runtime dependencies.
# Discovery reads the local path; it never fetches over the network during design.
reference_libraries:
  # By NAME — resolves to team-forge's pinned manifest reference-libraries/<name>.yaml
  # (repo URL + pinned commit). Discovery fetches the pinned commit on demand into a
  # local cache via tools/fetch_reference.py; never vendored, never loaded as skills.
  # team-forge ships the `ecc` pin (consumption: reference-and-adapt).
  - ecc
  # Or an ad-hoc library you manage yourself (local clone you keep current):
  # - { name: mylib, path: /abs/path/to/clone, agents_dir: agents, skills_dir: skills }

# ----------------------------------------------------------------------------
# asset_discovery — Phase 3 audit trail (skills AND agents).
# ----------------------------------------------------------------------------
# Logged for human review + future reference. Domain-filtered against project.domain.
asset_discovery:
  domain_filter: <project.domain>            # what the catalog was filtered to

  discovered_skills:
    project_local: [<skill-name>]            # <target_repo>/.claude/skills/
    user_global:   [<skill-name>]            # ~/.claude/skills/
    plugins:
      team-forge: [brainstorming, design, forge, rehydrate, tracker, monitor, writing-plans]
      # superpowers: [...]
    reference_libraries:                     # domain-matched skills from reference libs
      ecc: [<skill-name>]                    # e.g. frontend-patterns, e2e-testing

  discovered_agents:
    project_local: [<agent-name>]            # <target_repo>/.claude/agents/
    user_global:   [<agent-name>]            # ~/.claude/agents/
    plugins:       {}                        # plugin agents by plugin name
    reference_libraries:                     # domain-matched agents from reference libs
      ecc: [<agent-name>]                    # e.g. code-reviewer, architect, tdd-guide

  # The four buckets the design agents act on:
  reuse_candidates:                          # installed, shared/domain-agnostic, domain-match → reference, don't re-emit
    - name: <agent-or-skill>
      source: <project_local | user_global | plugin>
      why: "<shared_across_teams + domain match>"
  adapt_candidates:                          # reference-library prior art → forge our own, cite the source
    - name: <ecc-agent-or-skill>
      source: ecc
      adapt_into: <new-roster-entry-name>
      borrowed: "<what pattern we took>"
  collision_list: [<existing-agent-or-skill-name>, ...]   # never emit a clashing name
  pattern_references: [<agent-or-team>, ...]               # role structures that informed the roster

  proposed_loadouts_per_teammate:            # final skills per teammate (also written into roster[].skills)
    <teammate-name>: [<skill>, <skill>]
