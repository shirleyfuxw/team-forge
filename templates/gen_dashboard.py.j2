#!/usr/bin/env python3
"""Dashboard renderer for `{{team}}` ({{archetype}} archetype).
Reads ../tracker/status.json, builds the unified dashboard payload, and injects it into
the shared team-forge shell (baked in below as SHELL). Deterministic render step — the
SAME warm-ivory interactive shell a monitor agent would write, produced by a script
instead of a standing agent. Re-run after each status.json update:
    python3 gen_dashboard.py
"""
import json, datetime
from pathlib import Path

HERE = Path(__file__).resolve().parent              # .../team-forge/{{team}}/playground
STATUS = HERE.parent / "tracker" / "status.json"
OUT = HERE / "dashboard.html"

TEAM = "{{team}}"
TITLE = "{{project_display_name}}"
BASENAME = "{{project_basename}}"
DOMAIN = "{{domain}}"
ARCHETYPE = "{{archetype}}"
PANEL_IDS = {{DASHBOARD_PANELS_JSON}}
MILESTONES = {{MILESTONES_JSON}}    # design-time facts baked in (team archetype; [] for workflow)
ROSTER = {{ROSTER_JSON}}
# The shared shell (CSS + client-side renderer) baked in as a constant, so this script is
# self-contained and never depends on the team-forge extension being present at runtime.
SHELL = {{DASHBOARD_SHELL_JSON}}

QUEUE_KEYS = ["eligible", "full_drain", "plan_gate", "in_flight", "pr_ready", "blocked"]
DATA_SLOT = "{{" + "DASHBOARD_DATA_JSON" + "}}"   # the runtime injection point in SHELL


def load():
    return json.loads(STATUS.read_text()) if STATUS.exists() else {}


def _now_iso():
    return datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def build_payload_workflow(d):
    """The unified dashboard payload — workflow archetype."""
    events = d.get("events") or []
    tasks = d.get("tasks") or []
    if not events:
        overall = "initial"
    elif tasks and all(str(t.get("status")) in ("done", "completed") for t in tasks):
        overall = "completed"
    else:
        overall = "running"
    budget = d.get("budget") or {}
    spend = d.get("token_spend_cumulative_k") or budget.get("spent_k") or 0
    return {
        "meta": {
            "team": TEAM, "project_display_name": TITLE, "project_basename": BASENAME,
            "domain": DOMAIN, "archetype": "workflow", "overall_status": overall,
            "current_task": d.get("current_task"), "token_spend_cumulative_k": spend,
            "last_update_iso": _now_iso(),
        },
        "panels": PANEL_IDS,
        "tasks": tasks,
        "gate_results": d.get("gate_results") or [],
        "integration_branch": d.get("integration_branch") or {},
        "tickets": d.get("tickets") or [],
        "queue": {k: d.get("queue_" + k, 0) for k in QUEUE_KEYS},
        "events": events[-30:],
    }


def build_payload_team(d):
    """The unified dashboard payload — agent-team archetype (rosters with no monitor
    teammate use this render step instead; same payload shape the monitor produces)."""
    events = d.get("events") or []
    ids = [m["id"] for m in MILESTONES]
    cur = d.get("current_milestone")
    cur_idx = ids.index(cur) if cur in ids else None
    done_ids = {e.get("milestone_id") or e.get("milestone")
                for e in events if e.get("kind") == "milestone_completed"}
    done_ids.discard(None)
    n_completed = sum(1 for e in events if e.get("kind") == "milestone_completed")
    final_id = ids[-1] if ids else None
    if not events:
        overall = "initial"
    elif final_id in done_ids or (cur_idx == len(ids) - 1 and n_completed >= len(ids) and ids):
        overall = "completed"
    else:
        overall = "running"

    def ms_status(mid, idx):
        if mid in done_ids:
            return "completed"
        if cur_idx is None:
            return "pending"
        if idx < cur_idx:
            return "completed"
        return "running" if idx == cur_idx else "pending"

    return {
        "meta": {
            "team": TEAM, "project_display_name": TITLE, "project_basename": BASENAME,
            "domain": DOMAIN, "archetype": "team", "overall_status": overall,
            "current_milestone": cur, "current_cohort_id": d.get("current_cohort_id"),
            "token_spend_cumulative_k": d.get("token_spend_cumulative_k", 0),
            "last_update_iso": _now_iso(),
        },
        "panels": PANEL_IDS,
        "milestones": [{"id": m["id"], "name": m["name"], "output": m.get("output", ""),
                        "status": ms_status(m["id"], i)} for i, m in enumerate(MILESTONES)],
        "roster": ROSTER,
        "pointers": {"brainstorm": d.get("current_brainstorm"),
                     "team_plan": d.get("current_team_plan")},
        "events": events[-30:],
    }


build_payload = build_payload_team if ARCHETYPE == "team" else build_payload_workflow


def render():
    payload = build_payload(load())
    # Escaping `<` keeps a `</script>` inside any string field from closing the tag early.
    data_json = json.dumps(payload, ensure_ascii=False).replace("<", "\\u003c")
    OUT.write_text(SHELL.replace(DATA_SLOT, data_json))
    print("wrote", OUT)


if __name__ == "__main__":
    render()
